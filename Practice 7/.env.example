# PostgreSQL Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mydb
DB_SSLMODE=disable

# JWT Secret
JWT_SECRET=your-secret-key-here

# Allow admin registration (for testing - register first user with "role": "admin")
# Set to 'true' to allow creating users with admin role during registration
ALLOW_ADMIN_REGISTRATION=true